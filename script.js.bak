<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NoteHub - Academic Collaboration Platform</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://accounts.google.com/gsi/client" async defer></script>
  </head>
  <body
    class="bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 text-white"
  >
    <div id="root"></div>

    <script>
      // Simple state management
      let currentPage = "landing";
      let isAdminLoggedIn = false;
      let showAdminLoginModal = false;
      let showAdminSignupModal = false;
      let isStudentLoggedIn = false;
      let showStudentLoginModal = false;
      let showStudentSignupModal = false;
      let showNoteUploadModal = false;
      let showNoteDetailModal = false;
      let selectedNoteDetail = null;
      let studentEmail = "";
      let studentPassword = "";
      let studentName = "";
      let studentId = null;
      let studentPoints = 0;
      let studentUploads = 0;
      let showRejectModal = false;
      let rejectNoteId = null;
      let rejectReason = "";
      let adminEmail = "";
      let adminPassword = "";
      let currentReviewMode = "pending";
      let newNoteTitle = "";
      let newNoteSubject = "Computer Science";
      let newNoteSemester = "Semester 5";
      let studentTab = "myNotes";
      let showCommentModal = false;
      let commentNoteId = null;
      let commentText = "";
      let showGoogleAuthModal = false;
      let googleAuthType = "admin"; // 'admin' or 'student'
      let googleAuthEmail = "";
      let careerChatMessages = [
        {
          id: 1,
          role: "ai",
          message: "Hello! I represent the Career AI. Based on your strong performance in Computer Engineering (Rank #1!), I see great potential in **Full Stack Development** and **AI Research**.",
          time: "Just now"
        }
      ];

      let chatMessages = [
        {
          id: 1,
          user: "Tushar",
          message: "Welcome to NoteHub!",
          time: "2 mins ago",
        },
        {
          id: 2,
          user: "Omkar",
          message: "Great platform for sharing notes!",
          time: "1 min ago",
        },
      ];

      const userProfile = {
        name: "Tushar Khandagale",
        email: "tushar@notehub.com",
        semester: "7th Semester",
        department: "Computer Engineering",
        uploads: 45,
        points: 892,
        rank: 1,
        badges: ["Top Contributor", "Verified Expert", "Team Player"],
        verifiedNotes: 42,
        collaborations: 23,
        name: "Guest User",
        email: "guest@notehub.com",
        semester: "N/A",
        department: "N/A",
        uploads: 0,
        points: 0,
        rank: 0,
        badges: [],
        verifiedNotes: 0,
        collaborations: 0,
      };

      const API_BASE_URL = "http://localhost:5000/api";
      let notes = [];

      // Authorized Admins Only
      // Admins are now managed via Backend whitelist

      const leaderboard = [
        {
          id: 1,
          name: "Tushar Khandagale",
          points: 892,
          rank: 1,
          uploads: 45,
          badges: 3,
        },
        {
          id: 2,
          name: "Omkar Pokharkar",
          points: 765,
          rank: 2,
          uploads: 38,
          badges: 2,
        },
        {
          id: 3,
          name: "Raj Jadhav",
          points: 698,
          rank: 3,
          uploads: 34,
          badges: 2,
        },
        {
          id: 4,
          name: "Raul Vishwajeetsinh",
          points: 587,
          rank: 4,
          uploads: 29,
          badges: 1,
        },
      ];

      function navigateTo(page) {
        currentPage = page;
        render();
      }

      function render() {
        try {
          const root = document.getElementById("root");
          let html = getNavigation();

          if (currentPage === "landing") {
            html += getLandingPage();
          } else if (currentPage === "notes") {
            html += getNotesPage();
          } else if (currentPage === "collab") {
            html += getCollaborationPage();
          } else if (currentPage === "gamify") {
            html += getLeaderboardPage();
          } else if (currentPage === "career") {
            html += getCareerPage();
          } else if (
            currentPage === "student" ||
            currentPage === "student-dashboard"
          ) {
            html += getStudentDashboard();
          } else if (currentPage === "admin") {
            html += getAdminPage();
          }

          // Add Admin Login Modal
          if (showAdminLoginModal) {
            html += `
                        <div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
                            <div class="bg-slate-900 border border-purple-500/50 rounded-xl p-8 max-w-md w-full">
                                <div class="flex items-center justify-between mb-6">
                                    <h2 class="text-2xl font-bold">🔐 Admin Login</h2>
                                    <button onclick="closeAdminLoginModal()" class="text-gray-400 hover:text-white text-2xl">✕</button>
                                </div>
                                <div class="space-y-4">
                                    <div class="p-3 bg-purple-500/10 border border-purple-500/30 rounded text-xs text-purple-300">
                                        ⚠️ Authorized Admins Only - Students cannot access
                                    </div>
                                    
                                    <!-- Google Login Container -->
                                    <div id="googleBtnAdmin" class="w-full flex justify-center"></div>
                                    
                                    <div class="flex items-center gap-2">
                                        <div class="flex-1 h-px bg-gray-600"></div>
                                        <span class="text-xs text-gray-400">OR</span>
                                        <div class="flex-1 h-px bg-gray-600"></div>
                                    </div>
                                    
                                    <input
                                        type="email"
                                        id="loginEmail"
                                        placeholder="Admin Email"
                                        class="w-full px-4 py-2 bg-slate-800/50 border border-white/10 rounded-lg focus:outline-none focus:border-blue-500 text-white"
                                        oninput="adminEmail = this.value"
                                    />
                                    <input
                                        type="password"
                                        id="loginPassword"
                                        placeholder="Password"
                                        class="w-full px-4 py-2 bg-slate-800/50 border border-white/10 rounded-lg focus:outline-none focus:border-blue-500 text-white"
                                        oninput="adminPassword = this.value"
                                    />
                                    <button
                                        onclick="handleAdminLogin()"
                                        class="w-full px-4 py-2 bg-gradient-to-r from-purple-500 to-pink-600 rounded-lg hover:shadow-lg transition font-semibold"
                                    >
                                        Login
                                    </button>
                                    <p class="text-center text-gray-400 text-sm text-xs">
                                        Authorized admin credentials required
                                    </p>
                                </div>
                            </div>
                        </div>
                    `;
          }

          // Add Admin Signup Modal
          if (showAdminSignupModal) {
            html += `
                        <div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
                            <div class="bg-slate-900 border border-red-500/30 rounded-xl p-8 max-w-md w-full">
                                <div class="flex items-center justify-between mb-6">
                                    <h2 class="text-2xl font-bold text-red-400">🔒 Admin Access Restricted</h2>
                                    <button onclick="closeAdminSignupModal()" class="text-gray-400 hover:text-white text-2xl">✕</button>
                                </div>
                                <div class="space-y-4">
                                    <div class="p-4 bg-red-500/10 border border-red-500/30 rounded-lg">
                                        <p class="text-sm text-red-300 font-semibold mb-3">⛔ Signup Disabled</p>
                                        <p class="text-xs text-gray-300 mb-4">Only pre-authorized administrators can access the Admin Dashboard.</p>
                                        <p class="text-xs text-gray-400 mb-3 font-semibold">Authorized Admins:</p>
                                        <div class="space-y-1 text-xs text-gray-400">
                                            <p>👤 Raj Jadhav - raj2005jadhav@gmail.com</p>
                                            <p>👤 Tushar Khandagale - tusharsk3412@gmail.com</p>
                                            <p>👤 Vishwajeet Raul - vishwajeetraul2611@gmail.com</p>
                                            <p>👤 Omkar Pokharkar - omkarpokharkar9595@gmail.com</p>
                                        </div>
                                    </div>
                                    <button
                                        onclick="switchToLogin()"
                                        class="w-full px-4 py-2 bg-blue-500 hover:bg-blue-600 rounded-lg font-semibold"
                                    >
                                        Back to Login
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
          }

          // Add Note Rejection Modal
          if (showRejectModal) {
            html += `
                        <div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
                            <div class="bg-slate-900 border border-red-500/30 rounded-xl p-8 max-w-md w-full">
                                <div class="flex items-center justify-between mb-6">
                                    <h2 class="text-2xl font-bold text-red-400">Reject Note</h2>
                                    <button onclick="closeRejectModal()" class="text-gray-400 hover:text-white text-2xl">✕</button>
                                </div>
                                <div class="space-y-4">
                                    <div class="p-4 bg-red-500/10 border border-red-500/20 rounded-lg">
                                        <p class="text-sm text-gray-300">Provide a reason why this note does not meet our content guidelines:</p>
                                    </div>
                                    <select 
                                        onchange="rejectReason = this.value"
                                        class="w-full px-4 py-2 bg-slate-800/50 border border-white/10 rounded-lg focus:outline-none focus:border-red-500 text-white"
                                    >
                                        <option value="">-- Select Reason --</option>
                                        <option value="Sexual or Adult Content">🚫 Sexual/Adult Content</option>
                                        <option value="Political Propaganda">📢 Political Propaganda</option>
                                        <option value="Not STEM Related">❌ Not STEM Related</option>
                                        <option value="Plagiarized Content">📋 Plagiarized Content</option>
                                        <option value="Poor Quality">⭐ Poor Quality/Incomplete</option>
                                        <option value="Irrelevant Material">🔀 Irrelevant Material</option>
                                        <option value="Offensive Language">💬 Offensive Language</option>
                                        <option value="Other">⚠️ Other</option>
                                    </select>
                                    <textarea
                                        onchange="rejectReason = (rejectReason.split('\\n')[0] || '') + '\\n' + this.value"
                                        placeholder="Additional details (optional)..."
                                        class="w-full px-4 py-2 bg-slate-800/50 border border-white/10 rounded-lg focus:outline-none focus:border-red-500 text-white h-24"
                                    ></textarea>
                                    <button
                                        onclick="rejectNote()"
                                        class="w-full px-4 py-2 bg-red-500/20 border border-red-500/50 rounded-lg hover:bg-red-500/30 transition font-semibold text-red-400"
                                    >
                                        ✕ Reject Note
                                    </button>
                                    <button
                                        onclick="closeRejectModal()"
                                        class="w-full px-4 py-2 bg-slate-800/50 border border-white/10 rounded-lg hover:border-white/30 transition font-semibold"
                                    >
                                        Cancel
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
          }

          // Add Student Login Modal
          if (showStudentLoginModal) {
            html += `
                        <div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
                            <div class="bg-slate-900 border border-white/10 rounded-xl p-8 max-w-md w-full">
                                <div class="flex items-center justify-between mb-6">
                                    <h2 class="text-2xl font-bold">👨‍🎓 Student Login</h2>
                                    <button onclick="closeStudentLoginModal()" class="text-gray-400 hover:text-white text-2xl">✕</button>
                                </div>
                                <div class="space-y-4">
                                    <!-- Google Login Container -->
                                    <div id="googleBtnLogin" class="w-full flex justify-center"></div>
                                    
                                    <div class="flex items-center gap-2">
                                        <div class="flex-1 h-px bg-gray-600"></div>
                                        <span class="text-xs text-gray-400">OR</span>
                                        <div class="flex-1 h-px bg-gray-600"></div>
                                    </div>
                                    
                                    <input
                                        type="email"
                                        placeholder="Student Email"
                                        class="w-full px-4 py-2 bg-slate-800/50 border border-white/10 rounded-lg focus:outline-none focus:border-blue-500 text-white"
                                        oninput="studentEmail = this.value"
                                    />
                                    <input
                                        type="password"
                                        placeholder="Password"
                                        class="w-full px-4 py-2 bg-slate-800/50 border border-white/10 rounded-lg focus:outline-none focus:border-blue-500 text-white"
                                        oninput="studentPassword = this.value"
                                    />
                                    <button
                                        onclick="handleStudentLogin()"
                                        class="w-full px-4 py-2 bg-gradient-to-r from-blue-500 to-cyan-600 rounded-lg hover:shadow-lg transition font-semibold"
                                    >
                                        Login
                                    </button>
                                    <p class="text-center text-gray-400 text-sm">
                                        Don't have an account?
                                        <button onclick="switchStudentToSignup()" class="text-blue-400 hover:text-blue-300">Sign up</button>
                                    </p>
                                </div>
                            </div>
                        </div>
                    `;
          }

          // Add Student Signup Modal
          if (showStudentSignupModal) {
            html += `
                        <div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
                            <div class="bg-slate-900 border border-white/10 rounded-xl p-8 max-w-md w-full">
                                <div class="flex items-center justify-between mb-6">
                                    <h2 class="text-2xl font-bold">Create Account</h2>
                                    <button onclick="closeStudentSignupModal()" class="text-gray-400 hover:text-white text-2xl">✕</button>
                                </div>
                                <div class="space-y-4">
                                    <!-- Google Signup Container -->
                                    <div id="googleBtnSignup" class="w-full flex justify-center"></div>
                                    
                                    <div class="flex items-center gap-2">
                                        <div class="flex-1 h-px bg-gray-600"></div>
                                        <span class="text-xs text-gray-400">OR</span>
                                        <div class="flex-1 h-px bg-gray-600"></div>
                                    </div>
                                    
                                    <input
                                        type="text"
                                        placeholder="Full Name"
                                        class="w-full px-4 py-2 bg-slate-800/50 border border-white/10 rounded-lg focus:outline-none focus:border-blue-500 text-white"
                                        oninput="studentName = this.value"
                                    />
                                    <input
                                        type="email"
                                        placeholder="Student Email"
                                        class="w-full px-4 py-2 bg-slate-800/50 border border-white/10 rounded-lg focus:outline-none focus:border-blue-500 text-white"
                                        oninput="studentEmail = this.value"
                                    />
                                    <input
                                        type="password"
                                        placeholder="Create Password"
                                        class="w-full px-4 py-2 bg-slate-800/50 border border-white/10 rounded-lg focus:outline-none focus:border-blue-500 text-white"
                                        oninput="studentPassword = this.value"
                                    />
                                    <button
                                        onclick="handleStudentSignup()"
                                        class="w-full px-4 py-2 bg-gradient-to-r from-green-500 to-emerald-600 rounded-lg hover:shadow-lg transition font-semibold"
                                    >
                                        Create Account
                                    </button>
                                    <p class="text-center text-gray-400 text-sm">
                                        Already have an account?
                                        <button onclick="switchStudentToLogin()" class="text-blue-400 hover:text-blue-300">Login</button>
                                    </p>
                                </div>
                            </div>
                        </div>
                    `;
          }

          root.innerHTML = html;
          attachEventListeners();
          setTimeout(initGoogleLogin, 100); // Initialize Google Buttons after render
        } catch (e) {
          document.getElementById(
            "root"
          ).innerHTML = `<div style="padding: 20px; color: red;">Error: ${e.message}</div>`;
          console.error(e);
        }
      }

      function getNavigation() {
        let navRight = "";
        if (isStudentLoggedIn) {
          navRight = `
                    <button onclick="navigateTo('student-dashboard')" class="px-4 py-2 bg-gradient-to-r from-purple-500 to-pink-600 rounded-lg hover:shadow-lg transition text-sm font-semibold">
                        📊 Dashboard
                    </button>
                    <button onclick="document.getElementById('quickFileInput').click()" class="px-4 py-2 bg-gradient-to-r from-blue-500 to-cyan-600 rounded-lg hover:shadow-lg transition text-sm font-semibold">
                        📤 Upload
                    </button>
                    <input type="file" id="quickFileInput" style="display:none" onchange="handleQuickFileUpload(event)" accept=".pdf,.doc,.docx,.txt" />
                    <div class="flex items-center gap-2">
                        <span class="text-xs bg-yellow-500/20 px-2 py-1 rounded">${studentPoints} 🎯</span>
                        <div class="text-sm font-semibold text-blue-400">${
                          studentName || "Student"
                        }</div>
                    </div>
                    <button onclick="studentLogout()" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white border border-red-500 rounded-lg transition text-sm flex items-center gap-2 shadow-lg">
                        🚪 Log Out
                    </button>
                `;
        } else if (isAdminLoggedIn) {
          navRight = `
                    <button onclick="navigateTo('admin')" class="px-4 py-2 bg-gradient-to-r from-red-500 to-orange-600 rounded-lg hover:shadow-lg transition text-sm font-semibold">
                        ⚙️ Admin Panel
                    </button>
                    <div class="flex items-center gap-2">
                         <div class="text-sm font-semibold text-red-400">${
                           studentName || "Admin"
                         }</div>
                    </div>
                    <button onclick="adminLogout()" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white border border-red-500 rounded-lg transition text-sm flex items-center gap-2 shadow-lg">
                        🚪 Log Out
                    </button>
                `;
        } else {
          navRight = `
                    <div class="relative group">
                        <button class="px-4 py-2 bg-blue-500 hover:bg-blue-600 rounded-lg font-semibold text-sm flex items-center">
                            🔐 Login
                            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                            </svg>
                        </button>
                        <div class="absolute right-0 mt-0 w-48 bg-slate-900 border border-white/20 rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                            <button onclick="openStudentLoginModal()" class="w-full text-left px-4 py-3 hover:bg-slate-800 flex items-center text-sm font-semibold border-b border-white/10">
                                👨‍🎓 Student Login
                            </button>
                            <button onclick="openAdminLoginModal()" class="w-full text-left px-4 py-3 hover:bg-slate-800 flex items-center text-sm font-semibold">
                                🔐 Admin Login
                            </button>
                        </div>
                    </div>
                `;
        }

        return `
                <nav class="fixed w-full z-50 bg-slate-900/95 backdrop-blur-lg shadow-lg">
                    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                        <div class="flex justify-between items-center h-16">
                            <div class="flex items-center space-x-2 cursor-pointer" onclick="navigateTo('landing')">
                                <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-lg flex items-center justify-center">
                                    📖
                                </div>
                                <span class="text-2xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
                                    NoteHub
                                </span>
                            </div>
                            <div class="hidden md:flex space-x-8">
                                <button onclick="navigateTo('landing')" class="hover:text-blue-400 transition">Home</button>
                                <button onclick="navigateTo('notes')" class="hover:text-blue-400 transition">Notes</button>
                                <button onclick="navigateTo('career')" class="hover:text-blue-400 transition">Career AI</button>
                                <button onclick="navigateTo('student')" class="hover:text-blue-400 transition">Student</button>
                                <button onclick="navigateTo('admin')" class="hover:text-blue-400 transition">Admin</button>
                            </div>
                            <div class="flex items-center space-x-2">
                                ${navRight}
                            </div>
                        </div>
                    </div>
                </nav>
            `;
      }

      function getLandingPage() {
        return `
                <div class="pt-16 min-h-screen">
                    <!-- Hero Section -->
                    <div class="min-h-screen flex flex-col items-center justify-center px-4 py-20">
                        <h1 class="text-6xl font-bold mb-6 bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent text-center">
                            Welcome to NoteHub
                        </h1>
                        <p class="text-xl text-gray-300 mb-12 max-w-2xl text-center">
                            The ultimate academic collaboration platform for students. Share, verify, and learn from high-quality notes.
                        </p>
                        <div class="flex gap-4 mb-16">
                            <button onclick="navigateTo('notes')" class="px-8 py-3 bg-gradient-to-r from-blue-500 to-purple-600 rounded-lg hover:shadow-lg transition font-semibold">
                                Browse Notes
                            </button>
                            <button onclick="navigateTo('gamify')" class="px-8 py-3 border-2 border-blue-400 rounded-lg hover:bg-blue-400/10 transition font-semibold">
                                View Leaderboard
                            </button>
                        </div>
                    </div>

                    <!-- Collaborations Insight Section -->
                    <div class="py-20 px-4 bg-gradient-to-r from-purple-500/10 to-pink-600/10 border-y border-white/10">
                        <div class="max-w-7xl mx-auto">
                            <div class="text-center mb-16">
                                <h2 class="text-4xl font-bold mb-4">🤝 Real-Time Collaboration</h2>
                                <p class="text-xl text-gray-300">Connect with peers in study groups and discussions</p>
                            </div>
                            <div class="grid md:grid-cols-3 gap-6">
                                <div class="bg-slate-800/50 border border-white/10 rounded-xl p-6 hover:border-white/30 transition">
                                    <div class="text-4xl mb-4">💬</div>
                                    <h3 class="text-xl font-bold mb-3">Study Groups</h3>
                                    <p class="text-gray-400 text-sm mb-4">Join subject-specific study groups to collaborate on assignments and prepare for exams together.</p>
                                    <div class="text-sm text-blue-400 font-semibold">18,342+ Active Members</div>
                                </div>
                                <div class="bg-slate-800/50 border border-white/10 rounded-xl p-6 hover:border-white/30 transition">
                                    <div class="text-4xl mb-4">📝</div>
                                    <h3 class="text-xl font-bold mb-3">Discussions</h3>
                                    <p class="text-gray-400 text-sm mb-4">Discuss verified notes with your peers, share insights, and clarify concepts together in real-time.</p>
                                    <div class="text-sm text-purple-400 font-semibold">68% Academic Focus</div>
                                </div>
                                <div class="bg-slate-800/50 border border-white/10 rounded-xl p-6 hover:border-white/30 transition">
                                    <div class="text-4xl mb-4">🌐</div>
                                    <h3 class="text-xl font-bold mb-3">Global Network</h3>
                                    <p class="text-gray-400 text-sm mb-4">Connect with students from different colleges and backgrounds to expand your academic network.</p>
                                    <div class="text-sm text-pink-400 font-semibold">500+ College Community</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Leadership Insight Section -->
                    <div class="py-20 px-4">
                        <div class="max-w-7xl mx-auto">
                            <div class="text-center mb-16">
                                <h2 class="text-4xl font-bold mb-4">🏆 Gamified Leadership</h2>
                                <p class="text-xl text-gray-300">Compete, earn achievements, and lead the leaderboard</p>
                            </div>
                            <div class="grid md:grid-cols-2 gap-8">
                                <div class="bg-gradient-to-br from-yellow-500/20 to-orange-600/20 border border-yellow-500/50 rounded-xl p-8">
                                    <div class="text-5xl mb-4">📊</div>
                                    <h3 class="text-2xl font-bold mb-4">Global Rankings</h3>
                                    <p class="text-gray-300 mb-6">Compete on the global leaderboard by earning points through uploads, verifications, and collaborations.</p>
                                    <div class="space-y-3">
                                        <div class="flex justify-between">
                                            <span class="text-gray-400">🥇 Top Rank Bonus</span>
                                            <span class="font-bold text-yellow-400">+500 Points</span>
                                        </div>
                                        <div class="flex justify-between">
