      function sendMessage() {
        const input = document.getElementById("messageInput");
        if (input && input.value.trim()) {
          chatMessages.push({
            id: chatMessages.length + 1,
            user: userProfile.name.split(" ")[0],
            message: input.value,
            time: "just now",
          });
          input.value = "";
          render();
        }
      }

// Gemini API Key is now secured in backend


      async function callGeminiAPI(userQuery) {
          // Show "Thinking..." state
          const tempId = Date.now();
          careerChatMessages.push({
            id: tempId,
            role: "ai",
            message: "Thinking... 🧠",
            time: "Just now"
          });
          render();

          try {
              // Call Backend Proxy
              const response = await fetch(`${API_BASE_URL}/career/chat`, {
                  method: "POST",
                  headers: {
                      "Content-Type": "application/json"
                  },
                  body: JSON.stringify({ message: userQuery })
              });

              if (!response.ok) {
                  const errorData = await response.json().catch(() => ({}));
                  console.error("Gemini API Error details:", errorData);
                  throw new Error(errorData.error?.message || `API Error: ${response.status} ${response.statusText}`);
              }

              const data = await response.json();
              let aiMsg = data.candidates[0].content.parts[0].text;
              
              // Simple Markdown parsing (Bold **text**)
              aiMsg = aiMsg.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');

              // Remove "Thinking..." and add real response
              careerChatMessages = careerChatMessages.filter(m => m.id !== tempId);
              careerChatMessages.push({
                id: Date.now(),
                role: "ai",
                message: aiMsg,
                time: "Just now"
              });
              
          } catch (error) {
              console.error("Gemini Connect Error:", error);
              // Remove thinking
              careerChatMessages = careerChatMessages.filter(m => m.id !== tempId);
              careerChatMessages.push({
                id: Date.now(),
                role: "ai",
                message: `⚠️ **Connection Error:** ${error.message}\n\nPlease check your internet connection or API key.`,
                time: "Just now"
              });
          }
          
          render();
      }

      function sendCareerMessage() {
        const input = document.getElementById("careerInput");
        if (input && input.value.trim()) {
          const userMsg = input.value;
          
          // Add User Message
          careerChatMessages.push({
            id: careerChatMessages.length + 1,
            role: "user",
            message: userMsg,
            time: "Just now"
          });
          
          input.value = "";
          render(); 
          
          // Call Real API
          callGeminiAPI(userMsg);
        }
      }

      function attachEventListeners() {
        // Collab Chat Listener
        const input = document.getElementById("messageInput");
        if (input) {
          input.addEventListener("keypress", (e) => {
            if (e.key === "Enter") {
              sendMessage();
            }
          });
        }
        
        // Career Chain Listener
        const careerInput = document.getElementById("careerInput");
        if (careerInput) {
          careerInput.addEventListener("keypress", (e) => {
            if (e.key === "Enter") {
              sendCareerMessage();
            }
          });
          // Auto-scroll to bottom
          const container = document.getElementById("careerChatContainer");
          if(container) container.scrollTop = container.scrollHeight;
        }
      }

