                            <h2 class="text-3xl font-bold mb-4">Please Login First</h2>
                            <p class="text-gray-400 mb-8">Sign in to access your student dashboard</p>
                            <button onclick="openStudentLoginModal()" class="px-8 py-3 bg-blue-500 hover:bg-blue-600 rounded-lg font-semibold">
                                Login as Student
                            </button>
                        </div>
                    </div>
                `;
        }

        return `
                <div class="pt-20 min-h-screen pb-20">
                    <!-- Student Header -->
                    <div class="bg-gradient-to-r from-blue-500 to-cyan-600 p-8 mb-8">
                        <div class="max-w-7xl mx-auto">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h1 class="text-4xl font-bold mb-2">Welcome back, ${studentName}! 👋</h1>
                                    <p class="text-blue-100">Keep learning and sharing knowledge with fellow students</p>
                                </div>
                                <div class="flex gap-4">
                                    <div class="bg-white/20 rounded-lg p-4 text-center">
                                        <div class="text-3xl font-bold">${studentUploads}</div>
                                        <div class="text-sm text-blue-100">Notes Uploaded</div>
                                    </div>
                                    <div class="bg-white/20 rounded-lg p-4 text-center">
                                        <div class="text-3xl font-bold">${studentPoints}</div>
                                        <div class="text-sm text-blue-100">Points Earned</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Student Tabs -->
                    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                        <div class="flex gap-4 mb-8 border-b border-white/10 overflow-x-auto">
                            <button onclick="studentTab = 'myNotes'; render()" class="px-6 py-3 border-b-2 whitespace-nowrap ${
                              studentTab === "myNotes"
                                ? "border-blue-500 text-blue-400"
                                : "border-transparent text-gray-400 hover:text-white"
                            }">
                                📝 My Notes (${
                                  notes.filter(
                                    (n) => n.uploader === studentName
                                  ).length
                                })
                            </button>
                            <button onclick="studentTab = 'verified'; render()" class="px-6 py-3 border-b-2 whitespace-nowrap ${
                              studentTab === "verified"
                                ? "border-blue-500 text-blue-400"
                                : "border-transparent text-gray-400 hover:text-white"
                            }">
                                ✅ Verified Notes (${
                                  notes.filter((n) => n.verified).length
                                })
                            </button>
                            <button onclick="studentTab = 'collaboration'; render()" class="px-6 py-3 border-b-2 whitespace-nowrap ${
                              studentTab === "collaboration"
                                ? "border-blue-500 text-blue-400"
                                : "border-transparent text-gray-400 hover:text-white"
                            }">
                                🤝 Collaborate
                            </button>
                            <button onclick="studentTab = 'leaderboard'; render()" class="px-6 py-3 border-b-2 whitespace-nowrap ${
                              studentTab === "leaderboard"
                                ? "border-blue-500 text-blue-400"
                                : "border-transparent text-gray-400 hover:text-white"
                            }">
                                🏆 Leaderboard
                            </button>
                        </div>

                        <!-- My Notes Tab -->
                        ${
                          studentTab === "myNotes"
                            ? `
                            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                                ${notes
                                  .filter((n) => n.uploader === studentName)
                                  .map(
                                    (note) => `
                                    <div class="bg-slate-800/50 border border-white/10 rounded-xl p-6 hover:border-white/30 transition">
                                        <div class="flex items-start justify-between mb-4">
                                            <div>
                                                <h3 class="font-bold text-lg mb-2">${
                                                  note.title
                                                }</h3>
                                                <div class="text-xs text-gray-400">
                                                    <p>${note.subject} • ${
                                      note.semester
                                    }</p>
                                                </div>
                                            </div>
                                            <div class="text-2xl">${
                                              note.verified ? "✅" : "⏳"
                                            }</div>
                                        </div>
                                        <div class="flex gap-4 text-sm text-gray-400 mb-4">
                                            <span>📥 ${
                                              note.downloads
                                            } downloads</span>
                                            <span>⭐ ${note.rating}/5</span>
                                        </div>
                                        ${
                                          note.verified
                                            ? `
                                            <button onclick="downloadNote(${note.id})" class="w-full px-3 py-2 bg-gradient-to-r from-green-500 to-emerald-600 rounded hover:shadow-lg transition text-sm font-semibold text-white">
                                                📥 Download Note
                                            </button>
                                        `
                                            : `
                                            <div class="text-xs text-yellow-400 p-2 bg-yellow-500/10 rounded">⏱️ Pending Admin Review</div>
                                        `
                                        }
                                    </div>
                                `
                                  )
                                  .join("")}
                            </div>
                        `
                            : ""
                        }

                        <!-- Verified Notes Tab -->
                        ${
                          studentTab === "verified"
                            ? `
                            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                                ${notes
                                  .filter((n) => n.verified)
                                  .map(
                                    (note) => `
                                    <div class="bg-slate-800/50 border border-green-500/30 rounded-xl p-6 hover:border-green-500/60 transition">
                                        <div class="flex items-start justify-between mb-4">
                                            <div>
                                                <h3 class="font-bold text-lg mb-2">${note.title}</h3>
                                                <p class="text-xs text-gray-400">by ${note.uploader}</p>
                                            </div>
                                            <div class="text-2xl">✅</div>
                                        </div>
                                        <div class="text-sm text-gray-300 mb-4">${note.subject} • ${note.semester}</div>
                                        <div class="flex gap-3 mb-4 text-sm">
                                            <span class="bg-yellow-500/20 px-2 py-1 rounded">⭐ ${note.rating}</span>
                                            <span class="bg-blue-500/20 px-2 py-1 rounded">👍 ${note.likes}</span>
                                        </div>
                                        <button onclick="downloadNote(${note.id})" class="w-full px-4 py-3 bg-gradient-to-r from-blue-500 to-cyan-600 rounded-lg hover:shadow-lg transition font-semibold text-white text-center">
                                            📥 Download Note
                                        </button>
                                    </div>
                                `
                                  )
                                  .join("")}
                            </div>
                        `
                            : ""
                        }

                        <!-- Collaboration Tab -->
                        ${
                          studentTab === "collaboration"
                            ? `
                            <div class="bg-slate-800/50 border border-white/10 rounded-xl p-8">
                                <h3 class="text-2xl font-bold mb-6">🤝 Real-time Collaboration</h3>
                                <div class="grid md:grid-cols-2 gap-6">
                                    <div class="bg-slate-900/50 rounded-lg p-6">
                                        <h4 class="font-bold mb-4">💬 Discuss with Peers</h4>
                                        <p class="text-gray-400 text-sm mb-4">Join discussions on verified notes and share insights with other students.</p>
                                        <button onclick="alert('💬 Open discussions coming soon!')" class="px-4 py-2 bg-blue-500/20 border border-blue-500/50 rounded hover:bg-blue-500/30 text-sm font-semibold">
                                            View Discussions
                                        </button>
                                    </div>
                                    <div class="bg-slate-900/50 rounded-lg p-6">
                                        <h4 class="font-bold mb-4">📊 Study Groups</h4>
                                        <p class="text-gray-400 text-sm mb-4">Create or join study groups to collaborate on assignments and exams.</p>
                                        <button onclick="alert('👥 Study groups feature coming soon!')" class="px-4 py-2 bg-purple-500/20 border border-purple-500/50 rounded hover:bg-purple-500/30 text-sm font-semibold">
                                            Join Groups
                                        </button>
                                    </div>
                                </div>
                            </div>
                        `
                            : ""
                        }

                        <!-- Leaderboard Tab -->
                        ${
                          studentTab === "leaderboard"
                            ? `
                            <div class="bg-slate-800/50 border border-white/10 rounded-xl p-8">
                                <h3 class="text-2xl font-bold mb-6">🏆 Global Leaderboard</h3>
                                <div class="space-y-3">
                                    ${[...leaderboard]
                                      .sort((a, b) => b.points - a.points)
                                      .map(
                                        (user, index) => `
                                        <div class="bg-slate-900/50 border ${
                                          user.name === studentName
                                            ? "border-blue-500/50 bg-blue-500/10"
                                            : "border-white/10"
                                        } rounded-lg p-4 flex items-center justify-between">
                                            <div class="flex items-center gap-4">
                                                <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-lg ${
                                                  index === 0
                                                    ? "bg-yellow-500 text-slate-900"
                                                    : index === 1
                                                    ? "bg-gray-400 text-slate-900"
                                                    : index === 2
                                                    ? "bg-orange-600"
                                                    : "bg-slate-700"
                                                }">
                                                    ${index + 1}
                                                </div>
                                                <div>
                                                    <div class="font-semibold">${
                                                      user.name
                                                    }${
                                          user.name === studentName
                                            ? " (You)"
                                            : ""
                                        }</div>
                                                    <div class="text-xs text-gray-400">${
                                                      user.uploads
                                                    } uploads • ${
                                          user.badges
                                        } badges</div>
                                                </div>
                                            </div>
                                            <div class="text-right">
                                                <div class="text-2xl font-bold text-purple-400">${
                                                  user.points
                                                }</div>
                                                <div class="text-xs text-gray-400">points</div>
                                            </div>
                                        </div>
                                    `
                                      )
                                      .join("")}
                                </div>
                            </div>
                        `
                            : ""
                        }
                    </div>
                </div>
            `;
      }

      function getAdminPage() {
        // If admin is not logged in, show login/signup screen
        if (!isAdminLoggedIn) {
          return `
                    <div class="pt-20 min-h-screen flex items-center justify-center">
                        <div class="max-w-md w-full px-4">
                            <div class="bg-gradient-to-br from-slate-800/50 to-slate-900/50 backdrop-blur-lg border border-white/10 rounded-2xl p-12 text-center">
                                <div class="w-16 h-16 bg-gradient-to-br from-red-500 to-orange-600 rounded-xl flex items-center justify-center text-3xl mx-auto mb-6">
                                    🔐
                                </div>
                                <h1 class="text-3xl font-bold mb-2">Admin Access Required</h1>
                                <p class="text-gray-400 mb-8">Please login or create an account to access the Admin Dashboard</p>
                                
                                <div class="space-y-3">
                                    <button onclick="openAdminLoginModal()" class="w-full px-6 py-3 bg-gradient-to-r from-blue-500 to-purple-600 rounded-lg hover:shadow-lg transition font-semibold text-white">
                                        🔓 Admin Login
                                    </button>
                                    <button onclick="openAdminSignupModal()" class="w-full px-6 py-3 bg-slate-800/50 border border-white/10 rounded-lg hover:border-blue-500 hover:text-blue-400 transition font-semibold">
                                        ➕ Create Admin Account
                                    </button>
                                </div>
                                
                                <div class="mt-8 p-4 bg-blue-500/10 border border-blue-500/30 rounded-lg">
                                    <p class="text-sm text-blue-300">Demo Credentials:</p>
                                    <p class="text-xs text-gray-400 mt-2">Email: admin@notehub.com<br/>Password: admin123</p>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
        }

        // If logged in, show full admin dashboard
        const verifiedCount = notes.filter((n) => n.verified).length;
        const pendingCount = notes.length - verifiedCount;

        const stats = [
          {
            label: "Total Notes",
            value: notes.length,
            change: "+12.5%",
            icon: "📄",
          },
          {
            label: "Verified Notes",
            value: verifiedCount,
            change: "+8.2%",
            icon: "✓",
          },
          {
            label: "Pending Verification",
            value: pendingCount,
            change: "-5.3%",
            icon: "🕐",
          },
          {
            label: "System Uptime",
            value: "99.8%",
            change: "+0.1%",
            icon: "📊",
          },
        ];

        return `
                <div class="pt-20 min-h-screen">
                    <div class="bg-slate-900/95 backdrop-blur-lg border-b border-white/10">
                        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center space-x-4">
                                    <div class="w-12 h-12 bg-gradient-to-br from-red-500 to-orange-600 rounded-xl flex items-center justify-center text-2xl">
                                        ⚙️
                                    </div>
                                    <div>
                                        <h1 class="text-2xl font-bold">Admin Dashboard</h1>
                                        <p class="text-sm text-gray-400">Manage platform content and users</p>
                                    </div>
                                </div>
                                <button onclick="adminLogout()" class="px-4 py-2 bg-red-500/20 border border-red-500/50 rounded-lg hover:bg-red-500/30 transition text-red-400 text-sm">
                                    🚪 Logout
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
                        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                            ${stats
                              .map(
                                (stat) => `
                                <div class="bg-slate-800/50 backdrop-blur-lg border border-white/10 rounded-xl p-6">
                                    <div class="flex items-center justify-between mb-4">
                                        <span class="text-3xl">${stat.icon}</span>
                                        <span class="text-xs text-green-400">${stat.change}</span>
                                    </div>
                                    <div class="text-2xl font-bold">${stat.value}</div>
                                    <div class="text-sm text-gray-400">${stat.label}</div>
                                </div>
                            `
                              )
                              .join("")}
                        </div>

                        <div class="grid lg:grid-cols-3 gap-6">
                            <div class="lg:col-span-2">
                                {/* Tabs for View Options */}
                                <div class="flex gap-2 mb-6">
                                    <button onclick="switchReviewMode('pending')" class="px-4 py-2 rounded-lg font-semibold transition ${
                                      currentReviewMode === "pending"
                                        ? "bg-blue-500 text-white"
                                        : "bg-slate-800/50 border border-white/10 text-gray-400 hover:text-white"
                                    }">
                                        📋 Pending Review
                                    </button>
                                    <button onclick="switchReviewMode('ai-scan')" class="px-4 py-2 rounded-lg font-semibold transition ${
                                      currentReviewMode === "ai-scan"
                                        ? "bg-purple-500 text-white"
                                        : "bg-slate-800/50 border border-white/10 text-gray-400 hover:text-white"
                                    }">
                                        🤖 AI Scanner
                                    </button>
                                    <button onclick="switchReviewMode('verified')" class="px-4 py-2 rounded-lg font-semibold transition ${
                                      currentReviewMode === "verified"
                                        ? "bg-green-500 text-white"
                                        : "bg-slate-800/50 border border-white/10 text-gray-400 hover:text-white"
                                    }">
                                        ✓ Approved
                                    </button>
                                </div>

                                {/* Pending Review Tab */}
                                ${
                                  currentReviewMode === "pending"
                                    ? `
                                    <div class="bg-slate-800/50 backdrop-blur-lg border border-white/10 rounded-xl p-6">
                                        <h2 class="text-2xl font-bold mb-6">📋 Pending Notes Review</h2>
                                        <div class="space-y-4">
                                            ${notes
                                              .filter((n) => !n.verified)
                                              .map(
                                                (note) => `
                                                <div class="p-5 bg-slate-900/50 rounded-lg border border-yellow-500/20 hover:border-yellow-500/50 transition">
                                                    <div class="flex justify-between items-start mb-4">
                                                        <div class="flex-1">
                                                            <h3 class="font-bold text-lg">${note.title}</h3>
                                                            <p class="text-sm text-gray-400 mt-1">
                                                                📤 Uploaded by: <span class="text-gray-300">${note.uploader}</span><br/>
                                                                📚 Subject: <span class="text-gray-300">${note.subject}</span><br/>
                                                                🎓 Semester: <span class="text-gray-300">${note.semester}</span>
                                                            </p>
                                                        </div>
                                                        <span class="px-3 py-1 bg-yellow-500/20 text-yellow-400 rounded-full text-xs font-semibold">⏳ Pending</span>
                                                    </div>
                                                    <div class="flex gap-2">
                                                        <button onclick="approveNote(${note.id})" class="flex-1 px-3 py-2 bg-green-500/20 border border-green-500/50 rounded-lg text-green-400 text-sm font-semibold hover:bg-green-500/30 transition">
                                                            ✓ Approve
                                                        </button>
                                                        <button onclick="openRejectModal(${note.id})" class="flex-1 px-3 py-2 bg-red-500/20 border border-red-500/50 rounded-lg text-red-400 text-sm font-semibold hover:bg-red-500/30 transition">
                                                            ✕ Reject
                                                        </button>
                                                        <button onclick="scanNoteAI(${note.id})" class="flex-1 px-3 py-2 bg-purple-500/20 border border-purple-500/50 rounded-lg text-purple-400 text-sm font-semibold hover:bg-purple-500/30 transition">
                                                            🤖 AI Scan
                                                        </button>
                                                    </div>
                                                </div>
                                            `
                                              )
                                              .join("")}
                                            ${
                                              notes.filter((n) => !n.verified)
                                                .length === 0
                                                ? '<p class="text-center text-gray-400 py-8">✓ All notes have been reviewed!</p>'
                                                : ""
                                            }
                                        </div>
                                    </div>
                                `
                                    : ""
                                }

                                {/* AI Scanner Tab */}
                                ${
                                  currentReviewMode === "ai-scan"
                                    ? `
                                    <div class="bg-slate-800/50 backdrop-blur-lg border border-white/10 rounded-xl p-6">
                                        <h2 class="text-2xl font-bold mb-6">🤖 AI Content Scanner</h2>
                                        <p class="text-gray-400 mb-6">Automated detection for inappropriate content, plagiarism, and non-academic material</p>
                                        <div class="space-y-4">
                                            ${notes
                                              .filter((n) => !n.verified)
                                              .map(
                                                (note) => `
                                                <div class="p-5 bg-slate-900/50 rounded-lg border border-purple-500/20">
                                                    <div class="flex justify-between items-start mb-4">
                                                        <div>
                                                            <h3 class="font-bold">${note.title}</h3>
                                                            <p class="text-sm text-gray-400 mt-2">By ${note.uploader}</p>
                                                        </div>
                                                        <button onclick="runAIScan(${note.id})" class="px-3 py-1 bg-purple-500 rounded text-white text-xs font-semibold hover:bg-purple-600">
                                                            Scan Now
                                                        </button>
                                                    </div>
                                                    <div id="ai-result-${note.id}" class="hidden mt-4 p-4 bg-slate-800/50 rounded-lg border border-purple-500/20">
                                                        <h4 class="font-semibold mb-3">📊 AI Scan Results:</h4>
                                                        <div class="space-y-2 text-sm">
                                                            <div class="flex justify-between">
                                                                <span>✓ Academic Content:</span>
                                                                <span class="text-green-400 font-bold">95%</span>
                                                            </div>
                                                            <div class="flex justify-between">
                                                                <span>⚠️ Plagiarism Risk:</span>
                                                                <span class="text-green-400 font-bold">2%</span>
                                                            </div>
                                                            <div class="flex justify-between">
                                                                <span>🚫 Inappropriate Content:</span>
                                                                <span class="text-green-400 font-bold">0%</span>
                                                            </div>
                                                            <div class="flex justify-between">
                                                                <span>📌 STEM Related:</span>
                                                                <span class="text-green-400 font-bold">Yes</span>
                                                            </div>
                                                        </div>
                                                        <div class="mt-4 p-3 bg-green-500/10 border border-green-500/30 rounded">
                                                            <p class="text-green-400 text-xs">✓ Content appears legitimate and suitable for publication</p>
                                                        </div>
                                                    </div>
                                                </div>
                                            `
                                              )
                                              .join("")}
                                        </div>
                                    </div>
                                `
                                    : ""
                                }

                                {/* Approved Notes Tab */}
                                ${
                                  currentReviewMode === "verified"
                                    ? `
                                    <div class="bg-slate-800/50 backdrop-blur-lg border border-white/10 rounded-xl p-6">
                                        <h2 class="text-2xl font-bold mb-6">✓ Approved Notes</h2>
                                        <div class="space-y-3">
                                            ${notes
                                              .filter((n) => n.verified)
                                              .map(
                                                (note) => `
                                                <div class="p-4 bg-slate-900/50 rounded-lg border border-green-500/20">
                                                    <div class="flex justify-between items-start">
                                                        <div>
                                                            <h3 class="font-bold">${note.title}</h3>
                                                            <p class="text-sm text-gray-400 mt-1">${note.uploader} • ${note.semester}</p>
                                                        </div>
                                                        <span class="px-3 py-1 bg-green-500/20 text-green-400 rounded-full text-xs font-semibold">✓ Verified</span>
                                                    </div>
                                                </div>
                                            `
                                              )
                                              .join("")}
                                            ${
                                              notes.filter((n) => n.verified)
                                                .length === 0
                                                ? '<p class="text-center text-gray-400 py-8">No approved notes yet</p>'
                                                : ""
                                            }
                                        </div>
                                    </div>
                                `
                                    : ""
                                }
                            </div>

                            <div class="space-y-6">
                                <div class="bg-gradient-to-br from-blue-500/20 to-cyan-600/20 border border-blue-500/50 rounded-xl p-6">
                                    <h3 class="text-xl font-bold mb-4">📊 Review Statistics</h3>
                                    <div class="space-y-3">
                                        <div class="flex justify-between">
                                            <span class="text-gray-400">Pending</span>
                                            <span class="font-bold text-yellow-400">${
                                              notes.filter((n) => !n.verified)
                                                .length
                                            }</span>
                                        </div>
                                        <div class="flex justify-between">
                                            <span class="text-gray-400">Verified</span>
                                            <span class="font-bold text-green-400">${
                                              notes.filter((n) => n.verified)
                                                .length
                                            }</span>
                                        </div>
                                        <div class="flex justify-between">
                                            <span class="text-gray-400">Verification Rate</span>
                                            <span class="font-bold text-green-400">${Math.round(
                                              (verifiedCount / notes.length) *
                                                100
                                            )}%</span>
                                        </div>
                                        <div class="w-full bg-slate-700 rounded-full h-2">
                                            <div class="bg-green-500 h-2 rounded-full" style="width: ${
                                              (verifiedCount / notes.length) *
                                              100
                                            }%"></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="bg-gradient-to-br from-purple-500/20 to-pink-600/20 border border-purple-500/50 rounded-xl p-6">
                                    <h3 class="text-xl font-bold mb-4">🔒 Content Guidelines</h3>
                                    <div class="space-y-2 text-xs text-gray-400">
                                        <p>✓ STEM domain educational notes only</p>
                                        <p>✓ No sexual or adult content</p>
                                        <p>✓ No political propaganda</p>
                                        <p>✓ No plagiarized material</p>
                                        <p>✓ Proper academic standards</p>
                                        <p>✓ Clear and organized format</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
      }

      // Review Mode Functions
      function switchReviewMode(mode) {
        currentReviewMode = mode;
        render();
      }

      async function approveNote(noteId) {
        try {
          const response = await fetch(
            `${API_BASE_URL}/notes/${noteId}/verify`,
            {
              method: "PUT",
            }
          );
          if (!response.ok) throw new Error("Failed to verify note");

          alert(`✓ Note approved successfully!`);
          loadNotesFromBackend(); // Refresh list
        } catch (error) {
          console.error("Error approving note:", error);
          alert("Failed to approve note");
        }
      }

      function openRejectModal(noteId) {
        showRejectModal = true;
        rejectNoteId = noteId;
        rejectReason = "";
        render();
      }

      function closeRejectModal() {
        showRejectModal = false;
        rejectNoteId = null;
        rejectReason = "";
        render();
      }

        async function rejectNote() {
            if (!rejectReason.trim()) {
                alert('Please provide a reason for rejection');
                return;
            }
            
            try {
               const response = await fetch(`${API_BASE_URL}/notes/${rejectNoteId}`, {
                    method: 'DELETE'
                });
                
                if (!response.ok) throw new Error('Failed to delete note');
                
                const note = notes.find(n => n.id === rejectNoteId);
                alert(`✕ Note "${note ? note.title : 'Unknown'}" has been rejected.\n\nReason: ${rejectReason}`);
                
                closeRejectModal();
                loadNotesFromBackend(); // Refresh list
            } catch (error) {
                console.error('Error rejecting note:', error);
                alert('Failed to reject note');
            }
        }

      function scanNoteAI(noteId) {
        const note = notes.find((n) => n.id === noteId);
        if (note) {
          alert(
            `🤖 AI Scan Complete for: "${note.title}"\n\n✅ Academic Content: 95%\n✅ Plagiarism Risk: 2%\n✅ Inappropriate Content: 0%\n✅ STEM Related: Yes\n✅ Quality: High\n\n✓ Result: Content is SUITABLE for publication\n\nRecommendation: APPROVE this note`
          );
        }
      }

      function runAIScan(noteId) {
        scanNoteAI(noteId);
      }

      // Initial render
      render();

      // Admin Login/Signup Functions
      function openAdminLoginModal() {
        showAdminLoginModal = true;
        adminEmail = "";
        adminPassword = "";
        render();
      }

      function openAdminSignupModal() {
        showAdminSignupModal = true;
        adminEmail = "";
        adminPassword = "";
        render();
      }

      function closeAdminLoginModal() {
        showAdminLoginModal = false;
        render();
      }

      function closeAdminSignupModal() {
        showAdminSignupModal = false;
        render();
      }

      function handleAdminLogin() {
        alert("🔒 Please use 'Sign in with Google' for Admin Access.\n\nManual login is deprecated for security.");
      }

      function handleAdminSignup() {
        alert(
          "❌ Admin Signup Disabled\n\nOnly pre-authorized administrators can access the Admin Dashboard.\n\nIf you are an authorized admin, please use the Login button."
        );
        showAdminSignupModal = false;
        render();
      }

      function adminLogout() {
        isAdminLoggedIn = false;
        studentName = "";
        adminEmail = "";
        adminPassword = "";
        alert("Logged out successfully");
        navigateTo("landing");
        render();
      }

        const GOOGLE_CLIENT_ID = '1091785937553-9tt7ut2hsslcu6q816h145uq1p0ceecq.apps.googleusercontent.com'; // TODO: User to replace this

        // Handle Google Response
        async function handleCredentialResponse(response) {
            console.log("Encoded JWT ID token: " + response.credential);
            try {
                const res = await fetch(`${API_BASE_URL}/auth/google`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: response.credential })
                });

                if (!res.ok) throw new Error('Google Auth Failed');

                const data = await res.json();
                console.log('Backend Auth Success:', data);
                
                // Determine context based on which modal was open
                if (showAdminLoginModal) {
                    // Admin Login Flow - Role check from Backend
                    if (data.user.role === 'admin') {
                        isAdminLoggedIn = true;
                        studentName = data.user.name; 
                        showAdminLoginModal = false;
                        showStudentLoginModal = false;
                        showStudentSignupModal = false;
                        
                        alert(`✓ Admin Access Granted!\nWelcome back, ${data.user.name}!`);
                        navigateTo('admin');
                    } else {
                        alert(`❌ Access Denied!\n\n${data.user.email} is not authorized as an Administrator.`);
                        isAdminLoggedIn = false;
                        google.accounts.id.disableAutoSelect();
                    }
                } else {
                    // Student Login Flow (Default)
                    isStudentLoggedIn = true;
                    studentName = data.user.name;
                    studentEmail = data.user.email;
                    studentId = data.user.id;
                    studentPoints = data.user.points || 0;
                    studentUploads = data.user.uploads || 0;
                    
                    // Close modals
                    showStudentLoginModal = false;
                    showStudentSignupModal = false;
                    
                    alert(`✓ Google Login Successful!\nWelcome, ${studentName}!`);
                    navigateTo('student-dashboard');
                }
                
            } catch (error) {
                console.error("Google verify error:", error);
                alert("Google Login failed. Please try again.");
            }
        }

        function initGoogleLogin() {
            if (typeof google !== 'undefined' && google.accounts) {
                google.accounts.id.initialize({
                    client_id: GOOGLE_CLIENT_ID,
                    callback: handleCredentialResponse
                });
                
                // Render button in all potential containers
                const containers = ['googleBtnLogin', 'googleBtnSignup', 'googleBtnAdmin'];
                containers.forEach(id => {
                    const params = { 
                        theme: 'outline', 
                        size: 'large',
                        width: '100%' // Responsive width
                    };
                    const element = document.getElementById(id);
                    if (element) {
                        google.accounts.id.renderButton(element, params);
                    }
                });
            }
        }

      function switchToLogin() {
        showAdminSignupModal = false;
        showAdminLoginModal = true;
        render();
      }

      // Student Login/Signup Functions
      function openStudentLoginModal() {
        showStudentLoginModal = true;
        studentEmail = "";
        studentPassword = "";
        render();
      }

      function openStudentSignupModal() {
        showStudentSignupModal = true;
        studentName = "";
        studentEmail = "";
        studentPassword = "";
        render();
      }

      function closeStudentLoginModal() {
        showStudentLoginModal = false;
        render();
      }

      function closeStudentSignupModal() {
        showStudentSignupModal = false;
        render();
      }

      function handleStudentLogin() {
        if (studentEmail && studentPassword) {
          isStudentLoggedIn = true;
          studentId = Math.floor(Math.random() * 1000);
          showStudentLoginModal = false;
          alert("✓ Student Login Successful!");
          studentEmail = "";
          studentPassword = "";
          navigateTo("student-dashboard");
        } else {
          alert("Please fill in all fields");
        }
      }

      function handleStudentSignup() {
        if (studentName && studentEmail && studentPassword) {
          isStudentLoggedIn = true;
          studentId = Math.floor(Math.random() * 1000);
          studentPoints = 10;
          studentUploads = 0;
          showStudentSignupModal = false;
          alert("✓ Account Created Successfully! Welcome to NoteHub");
          studentEmail = "";
          studentPassword = "";
          navigateTo("student-dashboard");
        } else {
          alert("Please fill in all fields");
        }
      }

      function studentLogout() {
        isStudentLoggedIn = false;
        studentEmail = "";
        studentPassword = "";
        studentName = "";
        alert("Logged out successfully");
        render();
      }

      function switchStudentToLogin() {
        showStudentSignupModal = false;
        showStudentLoginModal = true;
        render();
      }

      function switchStudentToSignup() {
        showStudentLoginModal = false;
        showStudentSignupModal = true;
        render();
      }

      // File upload handling functions
      let selectedFile = null;

      async function handleQuickFileUpload(event) {
        const file = event.target.files[0];
        if (!file) return;

        const maxSize = 50 * 1024 * 1024; // 50MB
        if (file.size > maxSize) {
          alert("❌ File size exceeds 50MB limit");
          return;
        }

        if (!isStudentLoggedIn) {
          alert("Please log in first to upload notes");
          openStudentLoginModal();
          return;
        }

        // Prompt for note title
        const title = prompt("📝 Enter a title for your note:");
        if (!title || !title.trim()) {
          alert("❌ Note title is required");
          return;
        }

        // Prompt for subject
        const subjects = [
          "Computer Science",
          "Mathematics",
          "Physics",
          "Chemistry",
          "Biology",
          "Engineering",
        ];
        const subject = prompt(
          "📚 Enter subject:\n\nOptions: " + subjects.join(", ")
        );
        if (!subject) return;

        // Prompt for semester
        const semesters = [
          "Semester 1",
          "Semester 2",
          "Semester 3",
          "Semester 4",
          "Semester 5",
          "Semester 6",
          "Semester 7",
          "Semester 8",
        ];
        const semester = prompt(
          "🎓 Select semester:\n\nOptions: " + semesters.join(", ")
        );
        if (!semester) return;

        // Upload to backend
        const formData = new FormData();
        formData.append("title", title.trim());
        formData.append("subject", subject);
        formData.append("semester", semester);
        formData.append("uploaderName", studentName || "Student");
        formData.append("fileType", "PDF"); // Defaulting to PDF logic for simplicity, or could extract from file.type
        formData.append("file", file);

        try {
          const response = await fetch(`${API_BASE_URL}/notes/upload`, {
            method: "POST",
            body: formData,
          });
          if (!response.ok) throw new Error("Upload failed");

          const newNote = await response.json();
          studentUploads += 1;
          studentPoints += 10; // Optimistic update

          alert(
            `✅ Success!\n\nNote: "${title}" uploaded.\nYou earned 10 points!\n\nYour note will be reviewed by an admin soon.`
          );
          loadNotesFromBackend(); // Refresh list

          // Reset file input
          document.getElementById("quickFileInput").value = "";
        } catch (error) {
          console.error("Error uploading note:", error);
          alert("Failed to upload note. Please try again.");
        }
      }

      function handleFileSelect(event) {
        const file = event.target.files[0];
        if (file) {
          const maxSize = 50 * 1024 * 1024; // 50MB
          if (file.size > maxSize) {
            alert("❌ File size exceeds 50MB limit");
            return;
          }
          selectedFile = file;
          document.getElementById("fileNameDisplay").textContent =
            "✓ " + file.name;
        }
      }

      function handleFileDrop(event) {
        event.preventDefault();
        event.stopPropagation();

        const files = event.dataTransfer.files;
        if (files.length > 0) {
          const file = files[0];
          const maxSize = 50 * 1024 * 1024; // 50MB
          if (file.size > maxSize) {
            alert("❌ File size exceeds 50MB limit");
            return;
          }
          selectedFile = file;
          document.getElementById("fileNameDisplay").textContent =
            "✓ " + file.name;
        }
      }

      // Student Upload Modal Functions
      function openNoteUploadModal() {
        if (!isStudentLoggedIn) {
          alert("Please log in first to upload notes");
          openStudentLoginModal();
          return;
        }
        showNoteUploadModal = true;
        newNoteTitle = "";
        newNoteSubject = "Computer Science";
        newNoteSemester = "Semester 5";
        render();
      }

      function closeNoteUploadModal() {
        showNoteUploadModal = false;
        render();
      }

      async function submitNoteUpload() {
        if (!newNoteTitle.trim()) {
          alert("Please enter a note title");
          return;
        }
        if (!selectedFile) {
          alert("Please select a file to upload");
          return;
        }

        const formData = new FormData();
        formData.append("title", newNoteTitle.trim());
        formData.append("subject", newNoteSubject);
        formData.append("semester", newNoteSemester);
        formData.append("uploaderName", studentName || "Student");
        formData.append(
          "fileType",
          selectedFile.type === "application/pdf" ? "PDF" : "DOC"
        );
        formData.append("file", selectedFile);

        try {
          const response = await fetch(`${API_BASE_URL}/notes/upload`, {
            method: "POST",
            body: formData,
          });
          if (!response.ok) throw new Error("Upload failed");

          studentUploads += 1;
          studentPoints += 5;
          alert(
            `✓ Note "${newNoteTitle}" uploaded successfully! You earned 5 points.\nIt will be reviewed by an admin soon.`
          );

          showNoteUploadModal = false;
          newNoteTitle = "";
          newNoteSubject = "Computer Science";
          newNoteSemester = "Semester 5";
          selectedFile = null;
          document.getElementById("fileNameDisplay").textContent = "";
          loadNotesFromBackend();
        } catch (error) {
          console.error("Error uploading note:", error);
          alert("Failed to upload note.");
        }
      }

      async function downloadNote(noteId) {
        console.log("Download requested for note:", noteId);
        const note = notes.find((n) => n.id === noteId);
        if (!note) {
          alert("❌ Note not found");
          return;
        }

        if (!note.verified) {
          alert(
            "⏳ This note has not been verified by admins yet. Only verified notes can be downloaded."
          );
          return;
        }

        try {
          // Increment download count
          await fetch(`${API_BASE_URL}/notes/${noteId}/download`, {
            method: "PUT",
          });

          if (note.fileName) {
            const downloadUrl = `${API_BASE_URL}/notes/file/${note.fileName}`;
            const link = document.createElement("a");
            link.href = downloadUrl;
            link.download = note.fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            alert(`✅ Download started: ${note.fileName}`);
            loadNotesFromBackend(); // Update count in UI
          } else {
            alert("❌ File not available directly.");
          }
        } catch (error) {
          console.error("Download error:", error);
          alert("Failed to download note");
        }
      }

      function switchToSignup() {
        showAdminLoginModal = false;
        showAdminSignupModal = true;
        render();
      }

      // Initialize on page load
      async function loadNotesFromBackend() {
        try {
          console.log("Fetching notes from backend...");
          const response = await fetch(`${API_BASE_URL}/notes/all`);
          if (!response.ok) throw new Error("Failed to fetch notes");
          const data = await response.json();

          // Transform backend data (snake_case) to frontend format (camelCase)
          notes = data.map((n) => ({
            id: n.id,
            title: n.title,
            uploader: n.uploader_name || "Anonymous",
            subject: n.subject || "General",
            semester: n.semester || "N/A",
            uploadDate: n.upload_date
              ? new Date(n.upload_date).toISOString().split("T")[0]
              : new Date().toISOString().split("T")[0],
            fileType: n.file_type || "PDF",
            fileSize: n.file_size || "Unknown",
            verified: n.verified,
            downloads: parseInt(n.downloads || 0),
            rating: parseFloat(n.rating || 0),
            likes: parseInt(n.likes || 0),
            fileName: n.file_name,
            fileUrl: n.file_url,
          }));

          console.log("Notes loaded:", notes.length);
          render();
        } catch (error) {
          console.error("Error loading notes:", error);
        }
      }

      // Initialize on page load
      document.addEventListener("DOMContentLoaded", function () {
        loadNotesFromBackend();
      });
    </script>
  </body>
</html>
